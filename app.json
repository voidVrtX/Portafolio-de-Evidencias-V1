{
  "expo": {
    "name": "Utopia Clinica Medica",
    "slug": "utopia-clinica-medica",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "utopia",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Permitir que Utopía use la cámara para escanear y fotografiar recetas médicas."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#14877d"
      },
      "permissions": [
        "CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que Utopía use la cámara para escanear y fotografiar recetas médicas."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
